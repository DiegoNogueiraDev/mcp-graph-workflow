{
  "name": "@mcp-graph-workflow/mcp-graph",
  "version": "5.28.1",
  "description": "MCP local-first PRD to task graph — transforms text into executable structure",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-graph": "dist/cli/index.js",
    "mcp-graph-stdio": "dist/mcp/stdio.js",
    "mcp-graph-server": "dist/mcp/server.js"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "dev": "tsx src/mcp/server.ts",
    "dev:stdio": "tsx src/mcp/stdio.ts",
    "dashboard:install": "cd src/web/dashboard && npm install",
    "dashboard:dev": "cd src/web/dashboard && npm run dev",
    "dashboard:build": "cd src/web/dashboard && npm run build",
    "build": "tsc && npm run copy-assets && npm run dashboard:build && npm run copy-dashboard",
    "copy-assets": "node -e \"const fs=require('fs');fs.cpSync('src/core/translation/ucr/construct-seed-data.json','dist/core/translation/ucr/construct-seed-data.json')\"",
    "copy-dashboard": "node -e \"const fs=require('fs');if(fs.existsSync('dist/web/dashboard/dist')){fs.rmSync('dist/web/dashboard/dist',{recursive:true})};fs.cpSync('src/web/dashboard/dist','dist/web/dashboard/dist',{recursive:true})\"",
    "start": "node dist/mcp/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:bench": "vitest bench",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 9",
    "lint:fix": "eslint src/ --fix",
    "setup:mcp": "bash scripts/setup-mcp.sh",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "prd",
    "task-graph",
    "local-first",
    "agent-tooling"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "author": "Diego Nogueira (https://github.com/DiegoNogueiraDev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiegoNogueiraDev/mcp-graph-workflow.git"
  },
  "homepage": "https://github.com/DiegoNogueiraDev/mcp-graph-workflow#readme",
  "bugs": {
    "url": "https://github.com/DiegoNogueiraDev/mcp-graph-workflow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "graphology": "^0.26.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@mcp-graph-workflow/mcp-graph": "^5.25.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.8",
    "lru-cache": "^11.2.7",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "update-notifier": "^7.3.1",
    "web-tree-sitter": "^0.26.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "intelephense": ">=1.10.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-lua": "^2.1.3",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "typescript": ">=5.0.0",
    "typescript-language-server": ">=4.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings 9"
    ],
    "src/**/*.tsx": [
      "eslint --max-warnings 9"
    ]
  }
}
